# This file has been auto-generated, direct editing is not recommended
# Find files under conf.d directory, which are stiched together to generate this file

# DONOT reload from i3msg, instead by default use Mod1+Ctrl+r or customise it your own key bind 

set $mod Mod1
set $mod1 Ctrl

# gaps
gaps inner 0
gaps outer 0
bindsym $mod+o gaps outer current plus 5
bindsym $mod+i gaps inner current plus 5
bindsym $mod+Shift+o gaps outer current minus 5
bindsym $mod+Shift+i gaps inner current minus 5

# Font for window titles
font pango:SourceCodePro 12px

exec_always sudo ryzenadj -a 18000 -b 18000 -c 18000 -f 90 --power-saving

# compisitor
# exec picom --config ~/.config/i3/picom.conf -b

#enable tapping on touchpad --- GOKUL
exec --no-startup-id xinput set-prop "SYNA32A5:00 06CB:CE17 Touchpad" "libinput Tapping Enabled" 1
#enable natural scrolling on touchpad --- GOKUL
exec --no-startup-id xinput set-prop "SYNA32A5:00 06CB:CE17 Touchpad" "libinput Natural Scrolling Enabled" 1

#set brightness of laptop screen to 15
exec --no-startup-id brightnessctl set 15%

# notebook fan controll deamon
exec sudo nbfc start

# lock screen
# exec "xautolock -detectsleep -time 3 -locker \"i3lock -c 000000\""

#Bind brighness keys and use brightnessctl to change brightness
bindsym XF86MonBrightnessDown exec --no-startup-id brightnessctl set 2%-
bindsym XF86MonBrightnessUp exec --no-startup-id brightnessctl set 2%+


# Use amixer to change volume.
bindsym XF86AudioRaiseVolume exec --no-startup-id amixer set Master 2%+ && $refresh_i3status
bindsym XF86AudioLowerVolume exec --no-startup-id amixer set Master 2%- && $refresh_i3status
bindsym XF86AudioMute exec --no-startup-id amixer set Master 1+ toggle && $refresh_i3status
bindsym XF86AudioPlay exec --no-startup-id playerctl play-pause
bindsym XF86AudioNext exec --no-startup-id playerctl next
bindsym XF86AudioPrev exec --no-startup-id playerctl previous
#bindsym XF86AudioMicMute exec --no-startup-id pactl set-source-mute @DEFAULT_SOURCE@ toggle && $refresh_i3status
#bindsym XF86Launch6 exec --no-startup Gnome-calculator

# Use Mouse+$mod to drag floating windows to their wanted position
floating_modifier $mod

# toggle tiling / floating
bindsym $mod+Shift+space floating toggle

# change focus between tiling / floating windows
bindsym $mod+space focus mode_toggle

# reload the configuration file
bindsym $mod+Shift+r exec --no-startup-id cat ~/.config/i3/conf.d/* > ~/.config/i3/config && i3-msg "restart"

# exit i3 (logs you out of your X session)
bindsym $mod+Shift+q exec i3-msg "exit"

# lockscreen manually
bindsym $mod+Shift+x exec i3lock -i /home/gokul/.config/i3/win-crash-lock-wal.png
# terminal
bindsym $mod+Shift+Return exec --no-startup-id i3-msg "workspace 3" && kitty
bindsym $mod+Return exec --no-startup-id i3-msg "workspace 3" && st ~/scripts/tmux_rc.sh

# dmenu (a program launcher)
bindsym $mod+d exec dmenu_run

# browser
bindsym $mod+b exec --no-startup-id i3-msg "workspace 2" && zen

# gui file manager
bindsym $mod+f exec --no-startup-id i3-msg "workspace 5" && dolphin

#bindsym $mod+p exec --no-startup-id i3-msg "workspace 5" && /usr/lib/pentablet/PenTablet.sh

bindsym $mod+m exec --no-startup-id i3-msg "workspace 4" && st -c music cmus

#assign workspace ---GOKUL
for_window [class="okular"] move to workspace 1
for_window [class="zen"] move to workspace 2
for_window [class="Brave-browser"] move to workspace 2
for_window [class="qutebrowser"] move to workspace 2
for_window [class="st"] move to workspace 3
for_window [class="kitty"] move to workspace 3
for_window [class="Spotify"] move to workspace 4
for_window [class="music"] move to workspace 4
for_window [class="dolphin"] move to workspace 5
#for_window [class="com.github.xournalpp.xournalpp"] move to workspace 4

#Floating rule -- GOKUL
for_window [class="Eog"] floating enable

#Fullscreen rule
for_window [class="zen"] fullscreen enable
for_window [class="music"] fullscreen enable

#for_window [class="kitty"] layout default
#for_window [class="st"] layout default
hide_edge_borders smart
title_align left
#default_border pixel 2

# kill focused window
bindsym $mod+q kill

# change focus
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

# alternatively, you can use the cursor keys:
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# move focused window
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

# alternatively, you can use the cursor keys:
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# split in horizontal orientation
bindsym $mod+- split h

# split in vertical orientation
bindsym $mod+| split v

# enter fullscreen mode for the focused container
bindsym $mod+Shift+f fullscreen toggle

# change container layout (stacked, tabbed, toggle split)
bindsym $mod+Shift+s layout stacking
bindsym $mod+Shift+t layout tabbed
bindsym $mod+Shift+e layout toggle split

# focus the parent container
bindsym $mod+a focus parent

# focus the child container
#bindsym $mod+d focus child

# class                 border  backgr. text    indicator child_border
client.focused          #ab20fd #000000 #ffffff #6622aa   #39ff14
client.focused_inactive #333333 #5f676a #ffffff #484e50   #5f676a
client.unfocused        #333333 #000000 #888888 #292d2e   #222222
client.urgent           #2f343a #900000 #ffffff #900000   #900000
client.placeholder      #000000 #0c0c0c #ffffff #000000   #0c0c0c

client.background       #ffffff
# switch to workspace
bindsym $mod+1 workspace "1"
bindsym $mod+2 workspace "2"
bindsym $mod+3 workspace "3"
bindsym $mod+4 workspace "4"
bindsym $mod+5 workspace "5"
bindsym $mod+6 workspace "6"
bindsym $mod+7 workspace "7"
bindsym $mod+8 workspace "8"
bindsym $mod+9 workspace "9"

# move focused container to workspace
bindsym $mod+Shift+1 move container to workspace "1"
bindsym $mod+Shift+2 move container to workspace "2"
bindsym $mod+Shift+3 move container to workspace "3"
bindsym $mod+Shift+4 move container to workspace "4"
bindsym $mod+Shift+5 move container to workspace "5"
bindsym $mod+Shift+6 move container to workspace "6"
bindsym $mod+Shift+7 move container to workspace "7"
bindsym $mod+Shift+8 move container to workspace "8"
bindsym $mod+Shift+9 move container to workspace "9"

workspace_layout tabbed

bindsym $mod+x move workspace to output next
mode "display" {
        bindsym p exec /home/gokul/.config/i3/only_main_display.sh
        bindsym s exec /home/gokul/.config/i3/only_second_display.sh
        bindsym b exec /home/gokul/.config/i3/both_display.sh
        bindsym Escape mode "default"
}

bindsym $mod+$mod1+d mode "display"
mode "powermenu"{

	bindsym p exec poweroff             #PowerOff
	bindsym r exec reboot               #ReBoot
	bindsym e exec i3-msg exit          #LogOut
	bindsym l exec i3lock               #Suspend
	bindsym Escape mode "default"
	bindsym $mod+$mod1+p mode "default"
}
bindsym $mod+$mod1+p mode "powermenu"
# resize window (you can also use the mouse for that)
mode "resize" {
        # These bindings trigger as soon as you enter the resize mode

        # Pressing left will shrink the window’s width.
        # Pressing right will grow the window’s width.
        # Pressing up will shrink the window’s height.
        # Pressing down will grow the window’s height.
        bindsym j resize shrink width 50 px or 5 ppt
        bindsym k resize grow height 50 px or 5 ppt
        bindsym l resize shrink height 50 px or 5 ppt
        bindsym semicolon resize grow width 50 px or 5 ppt

        # same bindings, but for the arrow keys
        bindsym Left resize shrink width 20 px or 2 ppt
        bindsym Down resize grow height 20 px or 2 ppt
        bindsym Up resize shrink height 20 px or 2 ppt
        bindsym Right resize grow width 20 px or 2 ppt

        # back to normal: Enter or Escape or $mod+r
        bindsym Return mode "default"
        bindsym Escape mode "default"
        bindsym $mod+$mod1+r mode "default"
}

bindsym $mod+$mod1+r mode "resize"
bar {
        status_command i3status -c ~/.config/i3/i3status.conf
        position bottom
        # :workspace_buttonsfont -xos4-terminus-medium-r-normal--12-120-72-72-C-60-iso8859-1
        font pango:DejaVu Sans Mono 12
    workspace_buttons yes
        colors  {
        background #0F0F0F
        statusline #D5D5D5
        focused_workspace #ffffff #000000
        active_workspace #ffffff #5697B2
        inactive_workspace #000000 #ffffff
        urgent_workspace #E5E5E5 #BC9B54
      }
}
